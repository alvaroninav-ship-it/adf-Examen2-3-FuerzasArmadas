{
	"name": "df_silver_efectivos",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronce_tbl_efectivos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_efectivos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_efectivo as integer,",
				"          id_especialidad as integer,",
				"          id_unidad_actual as integer,",
				"          id_rango_actual as integer,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as string,",
				"          estado as string,",
				"          salario_mensual as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(id_efectivo = toInteger(id_efectivo),",
				"          nombre = trim(upper(nombre)),",
				"          ci = trim(ci),",
				"          genero = iif(upper(trim(genero))=='M', 'Masculino',                         iif(upper(trim(genero))=='F', 'Femenino', 'N/A')),",
				"          fecha_nacimiento = toDate(fecha_nacimiento, 'yyyy-MM-dd'),",
				"          fecha_ingreso = toDate(fecha_ingreso, 'yyyy-MM-dd'),",
				"          departamento_origen = trim(upper(departamento_origen)),",
				"          estado = iif(isNull(estado), 'ACTIVO', trim(upper(estado))),",
				"          salario_mensual = toDecimal(salario_mensual, 10, 2),",
				"          id_especialidad = toInteger(id_especialidad),",
				"          id_unidad_actual = toInteger(id_unidad_actual),",
				"          id_rango_actual = toInteger(id_rango_actual)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_efectivo as integer,",
				"          id_especialidad as integer,",
				"          id_unidad_actual as integer,",
				"          id_rango_actual as integer,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as date,",
				"          estado as string,",
				"          salario_mensual as decimal(10,2)",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}