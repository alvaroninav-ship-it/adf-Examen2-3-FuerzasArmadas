{
	"name": "cargar_datos",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_tbl_efectivos",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"name": "source2"
				}
			],
			"sinks": [
				{
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_efectivo as integer,",
				"          id_especialidad as integer,",
				"          id_unidad_actual as integer,",
				"          id_rango_actual as integer,",
				"          nombre as string,",
				"          ci as string,",
				"          fecha_nacimiento as string,",
				"          genero as string,",
				"          departamento_origen as string,",
				"          fecha_ingreso as string,",
				"          estado as string,",
				"          salario_mensual as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source2",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}