{
	"name": "df_silver_zonas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_tbl_zonas",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_zonas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_zona as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as string,",
				"          nivel_riesgo as string,",
				"          acceso_carretero as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(id_zona = toInteger(id_zona),",
				"          nombre = trim(upper(nombre)),",
				"          departamento = trim(upper(departamento)),",
				"          frontera_con = iif(isNull(frontera_con), 'NINGUNA',                          trim(upper(frontera_con))),",
				"          tipo_terreno = trim(upper(tipo_terreno)),",
				"          altitud_msnm = toInteger(altitud_msnm),",
				"          nivel_riesgo = iif(isNull(nivel_riesgo), 'MEDIO',                          trim(upper(nivel_riesgo))),",
				"          acceso_carretero = iif(lower(trim(acceso_carretero))=='si'                         || lower(trim(acceso_carretero))=='sí'                         || lower(trim(acceso_carretero))=='1',                         true(), false())) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_zona as integer,",
				"          nombre as string,",
				"          departamento as string,",
				"          frontera_con as string,",
				"          tipo_terreno as string,",
				"          altitud_msnm as integer,",
				"          nivel_riesgo as string,",
				"          acceso_carretero as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}