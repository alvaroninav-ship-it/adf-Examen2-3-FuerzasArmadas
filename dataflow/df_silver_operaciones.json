{
	"name": "df_silver_operaciones",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_tbl_operaciones",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_operaciones",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as string,",
				"          fecha_fin as string,",
				"          efectivos_desplegados as string,",
				"          vehiculos_utilizados as string,",
				"          duracion_dias as string,",
				"          costo_operacion as string,",
				"          resultado as string,",
				"          detenidos as string,",
				"          area_km2 as string,",
				"          incidentes as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(id_operacion = toInteger(id_operacion),",
				"          id_tipo = toInteger(id_tipo),",
				"          id_unidad_resp = toInteger(id_unidad_resp),",
				"          id_zona = toInteger(id_zona),",
				"          nombre_operacion = trim(upper(nombre_operacion)),",
				"          fecha_inicio = toDate(fecha_inicio, 'yyyy-MM-dd'),",
				"          fecha_fin = toDate(fecha_fin, 'yyyy-MM-dd'),",
				"          efectivos_desplegados = toInteger(efectivos_desplegados),",
				"          vehiculos_utilizados = toInteger(vehiculos_utilizados),",
				"          duracion_dias = toInteger(duracion_dias),",
				"          costo_operacion = toDecimal(costo_operacion, 15, 2),",
				"          resultado = iif(isNull(resultado), 'SIN RESULTADO',                              trim(upper(resultado))),",
				"          detenidos = iif(isNull(detenidos), 0, toInteger(detenidos)),",
				"          area_km2 = toDecimal(area_km2, 10, 2),",
				"          incidentes = iif(isNull(incidentes), 'NINGUNO',                              trim(upper(incidentes))),",
				"          observaciones = iif(isNull(observaciones), 'SIN OBSERVACION',                              trim(observaciones))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_operacion as integer,",
				"          id_tipo as integer,",
				"          id_unidad_resp as integer,",
				"          id_zona as integer,",
				"          nombre_operacion as string,",
				"          fecha_inicio as date,",
				"          fecha_fin as date,",
				"          efectivos_desplegados as integer,",
				"          vehiculos_utilizados as integer,",
				"          duracion_dias as integer,",
				"          costo_operacion as decimal(15,2),",
				"          resultado as string,",
				"          detenidos as integer,",
				"          area_km2 as decimal(10,2),",
				"          incidentes as string,",
				"          observaciones as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}