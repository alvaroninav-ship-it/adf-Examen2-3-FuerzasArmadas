{
	"name": "df_silver_movimientos_personal",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_tbl_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_movimientos_personal",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo as integer,",
				"          fecha_movimiento as string,",
				"          antiguedad_anios as string,",
				"          salario_mensual as string,",
				"          observaciones as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(id_movimiento = toInteger(id_movimiento),",
				"          id_efectivo = toInteger(id_efectivo),",
				"          id_unidad_destino = toInteger(id_unidad_destino),",
				"          id_rango = toInteger(id_rango),",
				"          id_tipo = toInteger(id_tipo),",
				"          fecha_movimiento = toDate(fecha_movimiento, 'yyyy-MM-dd'),",
				"          antiguedad_anios = toInteger(antiguedad_anios),",
				"          salario_mensual = toDecimal(salario_mensual, 10, 2),",
				"          observaciones = iif(isNull(observaciones), 'SIN OBSERVACION',                          trim(observaciones))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_movimiento as integer,",
				"          id_efectivo as integer,",
				"          id_unidad_destino as integer,",
				"          id_rango as integer,",
				"          id_tipo as integer,",
				"          fecha_movimiento as date,",
				"          antiguedad_anios as integer,",
				"          salario_mensual as decimal(10,2),",
				"          observaciones as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}