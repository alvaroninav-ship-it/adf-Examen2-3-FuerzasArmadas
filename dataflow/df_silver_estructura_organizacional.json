{
	"name": "df_silver_estructura_organizacional",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_tbl_estructura_organizacional",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_estructura_organizacional",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_estructura as integer,",
				"          id_padre as integer,",
				"          nivel as integer,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          cobertura_departamentos as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 derive(id_estructura = toInteger(id_estructura),",
				"          id_padre = iif(isNull(id_padre), 0, toInteger(id_padre)),",
				"          nivel = toInteger(nivel),",
				"          nombre = trim(upper(nombre)),",
				"          sigla = trim(upper(sigla)),",
				"          tipo = trim(upper(tipo)),",
				"          cobertura_departamentos = iif(isNull(cobertura_departamentos),                              'NO ESPECIFICADO',                              trim(cobertura_departamentos))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_estructura as integer,",
				"          id_padre as integer,",
				"          nivel as integer,",
				"          nombre as string,",
				"          sigla as string,",
				"          tipo as string,",
				"          cobertura_departamentos as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}