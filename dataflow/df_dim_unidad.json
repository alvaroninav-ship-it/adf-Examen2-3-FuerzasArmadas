{
	"name": "df_dim_unidad",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_unidades",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "gold_dim_unidad",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_unidad as integer,",
				"          id_brigada as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    u.id_unidad,\\n    u.nombre,\\n    u.codigo,\\n    u.ciudad,\\n    u.departamento,\\n    u.tipo_cuartel,\\n    eo.nombre       AS brigada,\\n    eo.tipo         AS rama\\nFROM silver.unidades u\\nLEFT JOIN silver.estructura_organizacional eo\\n    ON u.id_brigada = eo.id_estructura',",
				"     format: 'query') ~> source1",
				"source1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_unidad as integer,",
				"          nombre as string,",
				"          codigo as string,",
				"          ciudad as string,",
				"          departamento as string,",
				"          tipo_cuartel as string,",
				"          brigada as string,",
				"          division as string,",
				"          rama as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_unidad,",
				"          nombre,",
				"          codigo,",
				"          ciudad,",
				"          departamento,",
				"          tipo_cuartel",
				"     )) ~> sink1"
			]
		}
	}
}